# Gere uma chave forte e exclusiva para cada ambiente.
SECRET_KEY=change-me

# Use a URL Transaction pooler do Supabase (porta 6543) em produção/serverless.
# Exemplo:
# postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NOME=Administrador

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SESSION_COOKIE_SECURE=false
